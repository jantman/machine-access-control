      "authorizations_or": ["secondary_auth"],
      "alias": "Rotary Attachment"
    }
  },
  "second-relay-shared": {
    "authorizations_or": ["shared_auth"],
    "second_relay": {
      "authorizations_or": ["shared_auth"],
      "alias": "Shared Auth Accessory"
    }
